# PrismBB Drug — environment template.
# Copy to `.env` and fill in. docker-compose picks this up automatically.

# ----- Backend (FastAPI) -----------------------------------------------------
# Optional — set to enable real Agno LLM agents. Without it, the routes still
# work via direct RDKit + ADMET-AI fallback paths.
GROQ_API_KEY=

# Default model cache dir inside the container (mapped to docker volume)
ADMET_AI_CACHE_DIR=/data/admet_ai
HF_HOME=/data/huggingface

# ----- Frontend (Flask) ------------------------------------------------------
# Internal service URL — leave as-is for docker-compose.
BACKEND_URL=http://backend:8000

# Session secret. Replace in production.
SECRET_KEY=change-me-in-production
